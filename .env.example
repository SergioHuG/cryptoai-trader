# CryptoAI Trader — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# ── Kraken API ──────────────────────────────────────────
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://cryptoai:password@localhost:5432/cryptoai_trader
TEST_DATABASE_URL=postgresql://cryptoai:password@localhost:5432/cryptoai_trader_test

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change_this_to_a_random_secret_key

# ── Trading Mode ─────────────────────────────────────────
# Options: paper | live
# Default is always paper — never change to live without full Phase 2 validation
TRADING_MODE=paper

# ── AWS (production only) ────────────────────────────────
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ARN=
