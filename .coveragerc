[run]
omit =
    tests/*
    scripts/*
    */migrations/*
    api/main.py
    agents/coordinator.py
    agents/technical.py
    agents/sentiment.py
    agents/fundamental.py
    execution/paper.py
    execution/live.py
    backtest/*
    notifications/*
    dashboard/*
    data/feeds.py
    data/cache.py
    database/schemas.py
    database/session.py
    data/historical.py
[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
